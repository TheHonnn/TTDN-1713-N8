<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="attendance_rule_import_tree" model="ir.ui.view">
            <field name="name">attendance.rule.import.tree</field>
            <field name="model">attendance.rule.import</field>
            <field name="arch" type="xml">
                <tree string="Nhập luật AI">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="file_name"/>
                    <field name="state"/>
                    <field name="applied_rule_id"/>
                    <field name="create_date"/>
                </tree>
            </field>
        </record>

        <record id="attendance_rule_import_form" model="ir.ui.view">
            <field name="name">attendance.rule.import.form</field>
            <field name="model">attendance.rule.import</field>
            <field name="arch" type="xml">
                <form string="Nhập luật công ty bằng AI">
                    <header>
                        <button name="action_extract_text" type="object" string="1. Trích xuất" class="btn-primary"/>
                        <button name="action_parse_with_ai" type="object" string="2. Phân tích AI" class="btn-secondary"/>
                        <button name="action_apply_to_rule" type="object" string="3. Áp dụng" class="btn-success"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,extracted,parsed,applied"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="company_id"/>
                                <field name="target_rule_id"/>
                                <field name="applied_rule_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="file_name"/>
                                <field name="file_data" filename="file_name"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Nội dung trích xuất">
                                <field name="extracted_text" nolabel="1" widget="text"/>
                            </page>
                            <page string="Diễn giải AI">
                                <group>
                                    <group>
                                        <field name="parsed_company_name" readonly="1"/>
                                        <field name="parsed_shift_name" readonly="1"/>
                                        <field name="parsed_start_time" readonly="1"/>
                                        <field name="parsed_end_time" readonly="1"/>
                                        <field name="parsed_break_duration" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="parsed_allow_late_minutes" readonly="1"/>
                                        <field name="parsed_allow_early_minutes" readonly="1"/>
                                        <field name="parsed_is_default" readonly="1"/>
                                        <field name="parsed_workdays_text" readonly="1"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="parsed_penalty_note" readonly="1" widget="text"/>
                                    <field name="parsed_penalty_lines_text" readonly="1" widget="text"/>
                                    <field name="parsed_summary" readonly="1" widget="text"/>
                                </group>
                            </page>
                            <page string="JSON AI">
                                <field name="ai_result_json" nolabel="1" widget="text"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_attendance_rule_import" model="ir.actions.act_window">
            <field name="name">Nhập luật công ty (AI)</field>
            <field name="res_model">attendance.rule.import</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tải file nội quy công ty, dùng AI để parse và áp dụng vào cấu hình ca làm việc.
                </p>
            </field>
        </record>

        <menuitem id="menu_attendance_rule_import"
                  name="Nhập luật công ty (AI)"
                  parent="nhan_su_attendance_ai.menu_ai_attendance_root"
                  action="action_attendance_rule_import"
                  sequence="35"/>
    </data>
</odoo>