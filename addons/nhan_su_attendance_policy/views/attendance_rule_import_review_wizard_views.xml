<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="attendance_rule_import_review_wizard_form" model="ir.ui.view">
            <field name="name">attendance.rule.import.review.wizard.form</field>
            <field name="model">attendance.rule.import.review.wizard</field>
            <field name="arch" type="xml">
                <form string="Xem xét trước khi Áp dụng">
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <strong>Hãy kiểm tra và chỉnh sửa thông tin bên dưới trước khi áp dụng.</strong>
                            Bạn có thể thêm, xóa hoặc sửa từng bậc phạt trong bảng "Các bậc phạt".
                        </div>
                        <group string="Thông tin ca làm việc">
                            <group>
                                <field name="import_record_id" invisible="1"/>
                                <field name="company_id"/>
                                <field name="target_rule_id"/>
                                <field name="shift_name"/>
                                <field name="is_default"/>
                            </group>
                            <group>
                                <field name="start_time" widget="float_time"/>
                                <field name="end_time" widget="float_time"/>
                                <field name="break_duration" widget="float_time"/>
                                <field name="allow_late_minutes"/>
                                <field name="allow_early_minutes"/>
                            </group>
                        </group>
                        <group string="Ngày làm việc">
                            <group>
                                <field name="monday_work"/>
                                <field name="tuesday_work"/>
                                <field name="wednesday_work"/>
                                <field name="thursday_work"/>
                            </group>
                            <group>
                                <field name="friday_work"/>
                                <field name="saturday_work"/>
                                <field name="sunday_work"/>
                            </group>
                        </group>
                        <group string="Ghi chú phạt / nội quy">
                            <field name="notes" nolabel="1" widget="text" placeholder="Ghi chú thêm về chính sách phạt..."/>
                        </group>
                        <notebook>
                            <page string="Các bậc phạt">
                                <field name="penalty_line_ids">
                                    <tree editable="bottom" string="Bậc phạt">
                                        <field name="violation_type"/>
                                        <field name="min_minutes" string="Từ phút"/>
                                        <field name="max_minutes" string="Đến phút (0=∞)"/>
                                        <field name="deduct_work_day" string="Trừ công (ngày)"/>
                                        <field name="note" string="Ghi chú"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_confirm" type="object" string="Xác nhận Áp dụng" class="btn-primary"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
