<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_shift_assignment_wizard_form" model="ir.ui.view">
            <field name="name">shift.assignment.wizard.form</field>
            <field name="model">shift.assignment.wizard</field>
            <field name="arch" type="xml">
                <form string="Gán ca nhân viên">
                    <group>
                        <field name="department_id"/>
                        <field name="only_without_shift"/>
                        <field name="shift_id" required="1"/>
                    </group>
                    <group>
                        <field name="employee_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                    </group>
                    <footer>
                        <button name="action_assign_shift" string="Gán ca" type="object" class="btn-primary"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>